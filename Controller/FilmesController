package com.Bradesco.catalogo_de_filmes.Controller;


import com.Bradesco.catalogo_de_filmes.Entity.Filmes;
import com.Bradesco.catalogo_de_filmes.Service.FilmesService;
import org.springframework.http.HttpStatus;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.*;

import java.time.LocalDate;
import java.util.List;

@RestController
@RequestMapping(value = "/filmes")
public class FilmesController {

    private final FilmesService service;

    public FilmesController(FilmesService service) {
        this.service = service;
    }

    //CREATE -> POST
    @PostMapping(value = "/filmes/cadastrar")
    public ResponseEntity<Filmes> criar(@RequestBody Filmes filme){
        Filmes salvo = service.criar(filme);
        return ResponseEntity.status(HttpStatus.CREATED).body(salvo);
    }

    //READ ALL - GET
    @GetMapping(value = "/filmes/listar")
    public ResponseEntity<List<Filmes>> listar(){
        List<Filmes> lista = service.listarTodos();

        //if para retornar o status 204 verificando se a lista esta nula ou vazia
        if(lista == null || lista.isEmpty()){
            return ResponseEntity.noContent().build();
        }

        return ResponseEntity.ok(lista);
    }

    //READ ONE - GET
    //BUSCAS ESPECIFICAS

    //BUSCA POR ID
    @GetMapping(value = "/filmes/{id}")
    public ResponseEntity<Filmes> buscaPorId(@PathVariable Long id){
        return ResponseEntity.ok(service.buscaPorId(id));
    }

    // Se não houverem filmes, retorna um status HTTP 204 (Sem conteúdo).
    //BUSCA POR NOME
    @GetMapping(value = "/filmes/buscar-por-nome?nome={nome}")
    public ResponseEntity<List<Filmes>> buscaPorNome(String nome){
        List<Filmes> buscaNome = service.buscaPorNome(nome);
        if(buscaNome == null || buscaNome.isEmpty()){
            return ResponseEntity.noContent().build();
        }
        return ResponseEntity.ok(buscaNome);
    }

    //BUSCA POR GENERO
    @GetMapping(value = "/filmes/buscar-por-genero?genero={genero}")
    public ResponseEntity<List<Filmes>> buscaPorGenero(String genero){
        List<Filmes> buscaGenero = service.buscaPorGenero(genero);

        if(buscaGenero == null || buscaGenero.isEmpty()){
            return ResponseEntity.noContent().build();
        }
        return ResponseEntity.ok(buscaGenero);
    }
    //BUSCA POR DIRETOR
    @GetMapping(value = "/filmes/buscar-por-diretor?diretor={diretor}")
    public ResponseEntity<List<Filmes>> buscaPorDiretor(String diretor){
        List<Filmes> buscaDiretor = service.buscaPorDiretor(diretor);

        if(buscaDiretor == null || buscaDiretor.isEmpty()){
            return ResponseEntity.noContent().build();
        }

        return ResponseEntity.ok(buscaDiretor);
    }
    //BUSCA POR NOTA

    @GetMapping(value = "/filmes/buscar-por-nota/{nota}")
    public ResponseEntity<List<Filmes>> buscaPorNota(Integer nota){
        List<Filmes> buscaNota = service.buscaPorNota(nota);

        if(buscaNota == null || buscaNota.isEmpty()){
            return ResponseEntity.noContent().build();
        }
        return ResponseEntity.ok(buscaNota);
    }

    // BUSCA POR DATA

    @GetMapping(value = "/filmes/buscar-por-data-lancamento?dataInicio={dataInicio}&dataFim={dataFim}")
    public ResponseEntity<List<Filmes>> buscaPorData(LocalDate dataInicio, LocalDate dataFim){
        List<Filmes> buscaDatas = service.buscaPorDataLancamento(dataInicio,dataFim);

        if(buscaDatas == null || buscaDatas.isEmpty()){
            return ResponseEntity.noContent().build();
        }

        return ResponseEntity.ok(buscaDatas);
    }

    //BUSCA STATUS DA NOTA DE UM FILME PELO SEU ID
    @GetMapping(value = "/{id}/classificacao")
    public ResponseEntity<String> buscaClassificacao(@PathVariable Long id){
        Filmes filme = service.buscaPorId(id);
        return ResponseEntity.ok(filme.getClassificacao());
    }

}
